+            // Fallback: use tmpnam
+            char tmp[L_tmpnam];
+            if (std::tmpnam(tmp))
+            {
+                m_filename = std::string(tmp);
+                std::ofstream file(m_filename);
+                if (file.is_open())
+                {
+                    file << content;
+                    file.close();
+                }
+            }
+            else
+            {
+                m_filename = "/tmp/test_config_fallback.ini";
+                std::ofstream file(m_filename);
+                if (file.is_open())
+                {
+                    file << content;
+                    file.close();
+                }
+            }
